# Copy to .env.local and fill in (never commit .env.local)

# Required — Sanity write token (Editor role) from https://www.sanity.io/manage
SANITY_TOKEN=skYOUR_TOKEN_HERE

# Optional
SANITY_PROJECT_ID=9jhqpk3a
SANITY_DATASET=production

# Optional — AI translation (otherwise free Lingva/MyMemory)
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
LOVABLE_API_KEY=

# Translation backfill tuning
# TRANSLATE_PROVIDER=lingva
# TRANSLATE_DELAY_MS=1000
# DRY_RUN=1
# FORCE=1
# ONLY=homepage,article
