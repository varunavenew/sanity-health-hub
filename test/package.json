{
  "name": "test",
  "private": true,
  "version": "1.0.0",
  "main": "package.json",
  "license": "UNLICENSED",
  "scripts": {
    "dev": "sanity dev",
    "start": "sanity start",
    "build": "sanity build",
    "deploy": "sanity deploy",
    "deploy-graphql": "sanity graphql deploy",
    "backfill:en": "tsx sanity/backfill-english-i18n.ts",
    "backfill:en:dry": "DRY_RUN=1 tsx sanity/backfill-english-i18n.ts",
    "backfill:en:all": "bash sanity/run-english-backfill-batches.sh",
    "backfill:en:apply-cache": "tsx sanity/apply-english-from-cache.ts",
    "migrate:slugs:dry": "DRY_RUN=1 tsx sanity/migrate-i18n-slugs.ts",
    "migrate:slugs": "tsx sanity/migrate-i18n-slugs.ts",
    "migrate:slugs:en:dry": "DRY_RUN=1 tsx sanity/migrate-english-slugs.ts",
    "migrate:slugs:en": "tsx sanity/migrate-english-slugs.ts",
    "fix:articles:dry": "DRY_RUN=1 tsx sanity/fix-article-validation.ts",
    "fix:articles": "tsx sanity/fix-article-validation.ts",
    "fix:slug-keys:dry": "DRY_RUN=1 tsx sanity/fix-slug-keys.ts",
    "fix:slug-keys": "tsx sanity/fix-slug-keys.ts",
    "migrate:slugs:fix": "tsx sanity/migrate-i18n-slugs.ts",
    "migrate:i18n:faqs:dry": "DRY_RUN=1 ONLY=faq tsx sanity/migrate-i18n-all-pages.ts",
    "migrate:i18n:faqs": "ONLY=faq tsx sanity/migrate-i18n-all-pages.ts",
    "backfill:en:faqs:dry": "DRY_RUN=1 ONLY=faq tsx sanity/backfill-english-i18n.ts",
    "backfill:en:faqs": "ONLY=faq tsx sanity/backfill-english-i18n.ts",
    "migrate:i18n:nav:dry": "DRY_RUN=1 ONLY=siteSettings tsx sanity/migrate-i18n-all-pages.ts",
    "migrate:i18n:nav": "ONLY=siteSettings tsx sanity/migrate-i18n-all-pages.ts",
    "backfill:en:nav": "ONLY=siteSettings tsx sanity/backfill-english-i18n.ts",
    "migrate:i18n:reviews:dry": "DRY_RUN=1 ONLY=googleReview,googleReviewSettings tsx sanity/migrate-i18n-all-pages.ts",
    "migrate:i18n:reviews": "ONLY=googleReview,googleReviewSettings tsx sanity/migrate-i18n-all-pages.ts",
    "backfill:en:reviews": "ONLY=googleReview,googleReviewSettings tsx sanity/backfill-english-i18n.ts",
    "migrate:reviews:en:dry": "DRY_RUN=1 tsx sanity/migrate-google-reviews-en.ts",
    "migrate:reviews:en": "tsx sanity/migrate-google-reviews-en.ts",
    "migrate:clinic-hours": "tsx sanity/migrate-clinic-hours-i18n.ts",
    "migrate:clinic-hours:dry": "DRY_RUN=1 tsx sanity/migrate-clinic-hours-i18n.ts",
    "migrate:specialist-categories:dry": "DRY_RUN=1 tsx sanity/migrate-specialist-categories.ts",
    "migrate:specialist-categories": "tsx sanity/migrate-specialist-categories.ts",
    "migrate:specialist-booking-ids:dry": "DRY_RUN=1 tsx sanity/migrate-specialist-booking-category-ids.ts",
    "migrate:specialist-booking-ids": "tsx sanity/migrate-specialist-booking-category-ids.ts",
    "migrate:treatment-cta:dry": "DRY_RUN=1 tsx sanity/migrate-treatment-category-bottom-cta.ts",
    "migrate:treatment-cta": "tsx sanity/migrate-treatment-category-bottom-cta.ts",
    "migrate:treatment-sections:dry": "DRY_RUN=1 tsx sanity/migrate-treatment-sections.ts",
    "migrate:treatment-sections": "tsx sanity/migrate-treatment-sections.ts",
    "migrate:treatment-sections:no-en": "SKIP_EN=1 tsx sanity/migrate-treatment-sections.ts",
    "migrate:treatment-full:dry": "DRY_RUN=1 tsx sanity/migrate-treatment-full-content.ts",
    "migrate:treatment-full": "tsx sanity/migrate-treatment-full-content.ts",
    "migrate:treatment-full:no-en": "SKIP_EN=1 tsx sanity/migrate-treatment-full-content.ts",
    "create:flere-fagomrader-treatments:dry": "DRY_RUN=1 tsx sanity/create-missing-flere-fagomrader-treatments.ts",
    "create:flere-fagomrader-treatments": "tsx sanity/create-missing-flere-fagomrader-treatments.ts"
  },
  "keywords": [
    "sanity"
  ],
  "dependencies": {
    "@sanity/language-filter": "^5.0.1",
    "@sanity/vision": "^5.28.0",
    "dotenv": "^17.4.2",
    "react": "^19.2.2",
    "react-dom": "^19.2.2",
    "sanity": "^5.28.0",
    "sanity-plugin-iframe-pane": "^5.0.11",
    "sanity-plugin-internationalized-array": "^5.1.1",
    "styled-components": "^6.1.18"
  },
  "devDependencies": {
    "@sanity/eslint-config-studio": "^6.0.0",
    "@types/react": "^19.2",
    "@vitalets/google-translate-api": "^9.2.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.28",
    "postcss": "^8.5.6",
    "prettier": "^3.5",
    "tailwindcss": "^4.2.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8"
  },
  "prettier": {
    "semi": false,
    "printWidth": 100,
    "bracketSpacing": false,
    "singleQuote": true
  }
}
